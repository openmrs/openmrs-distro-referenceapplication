# ===========================================
# peruHCE - Variables de Entorno
# ===========================================
#
# Copia este archivo como .env y completa los valores:
#   cp .env.template .env
#
# PROFILES DISPONIBLES:
#   docker compose up -d                                        # Core
#   docker compose --profile fua up -d                          # + FUA Generator
#   docker compose --profile hapi up -d                         # + HAPI FHIR
#   docker compose --profile imaging up -d                      # + Imaging (OHIF/Orthanc)
#   docker compose --profile keycloak up -d                     # + Keycloak Auth
#   docker compose --profile monitoring up -d                   # + Observability
#   docker compose -f docker-compose.yml -f compose/ssl.yml up -d  # + SSL/HTTPS

# ===========================================
# CORE (obligatorias)
# ===========================================

# GitHub Packages - credenciales para descargar modulos privados durante build
GHP_USERNAME=
GHP_PASSWORD=

# OpenMRS database
OPENMRS_DB_USER=openmrs
MYSQL_OPENMRS_PASSWORD=
MYSQL_ROOT_PASSWORD=

# OCL Token para importar conceptos medicos
OMRS_OCL_TOKEN=

# Tag de imagenes Docker (qa, latest, prod)
TAG=qa
# ===========================================
# CORE (opcionales)
# ===========================================

# Replication y backup DB
# OMRS_DB_REPL_USER=openmrs_repl
# OMRS_DB_REPL_PASSWORD=
# OMRS_DB_BACKUP_USER=openmrs_backup
# OMRS_DB_BACKUP_PASSWORD=

# Frame ancestors para CSP (vacio por defecto)
# FRAME_ANCESTORS=

# ===========================================
# PROFILE: fua
# ===========================================
# Requiere: --profile fua
# Ademas, configurar FUA_CONFIG y FUA_LOCATIONS para el routing nginx del gateway.

# PERUHCE_FUA_GEN_DB_USER=fuagenerator
# PERUHCE_FUA_GEN_DB_PASSWORD=           # OBLIGATORIO - sin default
# PERUHCE_FUA_GEN_DB=fuagenerator
# PERUHCE_FUA_GEN_TOKEN=                 # OBLIGATORIO - sin default

# Routing nginx para FUA (pegar el bloque upstream/location como valor)
# FUA_CONFIG=
# FUA_LOCATIONS=

# ===========================================
# PROFILE: keycloak
# ===========================================
# Requiere: --profile keycloak

# KEYCLOAK_ADMIN=admin
# KEYCLOAK_ADMIN_PASSWORD=
# KC_DB_DATABASE=keycloak
# KC_DB_USERNAME=keycloak
# KC_DB_PASSWORD=
# KC_HOSTNAME=localhost
# KEYCLOAK_PORT=8180

# OIDC/Keycloak para frontend SPA
# KEYCLOAK_HOST=
# KEYCLOAK_REALM=
# KEYCLOAK_CLIENT_ID=
# SPA_URL=

# ===========================================
# PROFILE: hapi
# ===========================================
# Requiere: --profile hapi

# HAPI_DB_USER=hapi
# HAPI_DB_PASSWORD=                      # OBLIGATORIO - sin default
# HAPI_DB_NAME=hapi

# ===========================================
# PROFILE: monitoring
# ===========================================
# Requiere: --profile monitoring

# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=

# ===========================================
# SSL/HTTPS (override con -f compose/ssl.yml)
# ===========================================

# SSL_MODE=dev
# CERT_WEB_DOMAIN_COMMON_NAME=localhost
# CERT_WEB_DOMAINS=localhost,127.0.0.1
# CERT_RSA_KEY_SIZE=4096
# CERT_TEMP_CERT_DAYS=365
# CERT_RENEWAL_INTERVAL=30d
# CERT_ORG=Centro de Salud
# CERT_OU=sihsalus
# CERT_COUNTRY=PE
# CERT_STATE=Loreto
# CERT_LOCALITY=Maynas
